# Google Places API (server-side only — set in Vercel, never commit real values)
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# Admin dashboard (server-side only)
ADMIN_DASHBOARD_PASSWORD=

# Analytics storage — Upstash Redis via Vercel Storage (Marketplace → Upstash for Redis)
# Vercel auto-injects these when you connect the integration to this project:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Legacy Vercel KV names (also supported if present):
KV_REST_API_URL=
KV_REST_API_TOKEN=
