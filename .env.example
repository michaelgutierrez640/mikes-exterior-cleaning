# Copy to `.env.local` for local development, then set the same keys in Vercel
# (Project → Settings → Environment Variables) for Production + Preview builds.
#
# Vite embeds VITE_* values at build time — redeploy after changing them.

# Google Analytics 4 Measurement ID (Admin → Data Streams → Web → Measurement ID)
VITE_GA_MEASUREMENT_ID=

# Meta (Facebook) Pixel ID (Events Manager → Data Sources → Pixel ID)
VITE_META_PIXEL_ID=
