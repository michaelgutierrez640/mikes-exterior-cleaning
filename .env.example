# Public site config (optional — set in Vercel for NAP and Google Business Profile links in schema/footer)
VITE_BUSINESS_STREET_ADDRESS=
VITE_GOOGLE_REVIEWS_URL=

# Google Places API (server-side only — set in Vercel, never commit real values)
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# Admin dashboard (server-side only)
ADMIN_DASHBOARD_PASSWORD=

# Analytics + completed-job records — Upstash Redis via Vercel Storage
# Vercel auto-injects these when Upstash Redis is connected to this project:
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Also supported if present:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
STORAGE_REST_API_URL=
STORAGE_REST_API_TOKEN=

# Completed Jobs photo storage — Vercel Blob (server-side only; never expose to Vite/client)
# Connecting Blob in the Vercel project injects these automatically for Production + Preview:
BLOB_READ_WRITE_TOKEN=
# Also injected by Vercel Blob (unused by this app today; safe to leave set):
# BLOB_STORE_ID=
# BLOB_WEBHOOK_PUBLIC_KEY=
