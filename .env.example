# Public site config (optional — set in Vercel for NAP and Google Business Profile links in schema/footer)
VITE_BUSINESS_STREET_ADDRESS=
VITE_GOOGLE_REVIEWS_URL=

# Google Places API (legacy optional — Phase 1 sync uses Business Profile below)
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=

# Google Business Profile reviews sync (server-side only — never use VITE_ prefix)
# See docs/GOOGLE_REVIEWS_SYNC.md for OAuth + account/location setup steps.
GOOGLE_GBP_CLIENT_ID=
GOOGLE_GBP_CLIENT_SECRET=
GOOGLE_GBP_REFRESH_TOKEN=
GOOGLE_GBP_ACCOUNT_ID=
GOOGLE_GBP_LOCATION_ID=
# Shared secret for cron / automated sync (set CRON_SECRET to the same value on Vercel)
REVIEWS_SYNC_SECRET=
# Vercel Cron authorization header value — must match REVIEWS_SYNC_SECRET for daily sync
CRON_SECRET=

# Admin dashboard (server-side only)
ADMIN_DASHBOARD_PASSWORD=

# Analytics + completed-job records + private CRM leads — Upstash Redis via Vercel Storage
# Vercel auto-injects these when Upstash Redis is connected to this project:
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Also supported if present:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
STORAGE_REST_API_URL=
STORAGE_REST_API_TOKEN=

# Completed Jobs photo storage — Vercel Blob (server-side only; never expose to Vite/client)
# Connecting Blob in the Vercel project injects these automatically for Production + Preview:
BLOB_READ_WRITE_TOKEN=
# Also injected by Vercel Blob (unused by this app today; safe to leave set):
# BLOB_STORE_ID=
# BLOB_WEBHOOK_PUBLIC_KEY=

# CRM / Leads (Phase 1)
# Leads reuse the same Upstash Redis + ADMIN_DASHBOARD_PASSWORD above.
# Public create: POST /api/leads (no PII in response)
# Admin read/update: GET/PATCH /api/leads (cookie auth required)
# Do not expose lead data via public projects, sitemap, or analytics APIs.
