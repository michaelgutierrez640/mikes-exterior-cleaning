{
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/services/commercial-window-cleaning",
      "destination": "/services/residential-window-cleaning",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|sitemap\\.xml$|robots\\.txt$|assets/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/image.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
